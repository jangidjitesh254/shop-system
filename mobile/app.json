{
  "expo": {
    "name": "Shop Manager",
    "slug": "shop-manager-mobile",
    "scheme": "shopmanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#ffffff",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.shopmanager.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#2563eb"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan product barcodes to look up items and create bills."
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Shop Manager to use the camera to scan product barcodes.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiBaseUrl": "https://shop-system-hezz.onrender.com/api",
      "router": {},
      "eas": {
        "projectId": "192fd11f-db3d-4645-a9f9-34daec1c3cc9"
      }
    },
    "owner": "zitesh",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/192fd11f-db3d-4645-a9f9-34daec1c3cc9"
    }
  }
}
