# Copy this file to .env and fill in real values.
# Never commit .env — it's gitignored.

# Server
PORT=5000
NODE_ENV=development

# Database
# Local dev:  mongodb://localhost:27017/shop_system
# Atlas prod: mongodb+srv://USER:PASS@cluster.xxx.mongodb.net/shop_system?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/shop_system

# JWT — a long random string. Generate one:
#   PowerShell: [Convert]::ToBase64String((1..48 | % {Get-Random -Max 256} | % {[byte]$_}))
#   *nix:       openssl rand -base64 48
JWT_SECRET=replace_me_with_a_long_random_string

# Optional — the email of the user to auto-promote to admin on server boot.
# Register that email first, then (re)start the server.
ADMIN_EMAIL=you@yourshop.com
